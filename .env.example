# ── Base de données PostgreSQL ────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
DATABASE_URL="postgresql://digicommune:CHANGE_ME@localhost:5432/digicommune?schema=public"

# ── Identifiant de la commune ─────────────────────────────────────────────────
# Slug unique identifiant ce déploiement. Ex: cocody, plateau, yopougon
# Chaque déploiement = une commune.
COMMUNE_ID="cocody"

# ── Environnement ─────────────────────────────────────────────────────────────
# "production" en prod, "development" en local
NODE_ENV="production"

# ── Origine publique ──────────────────────────────────────────────────────────
# Obligatoire en production (SvelteKit adapter-node)
# Doit correspondre au domaine public de l'application
ORIGIN="https://cocody.digicommune.ci"

# ── Mot de passe temporaire pour la migration (optionnel) ─────────────────────
# Utilisé par scripts/migrate-json-to-pg.js
# DEFAULT_PASSWORD="DigiCommune2025!"

# ── Mot de passe superadmin pour le seed (optionnel) ─────────────────────────
# Utilisé par scripts/seed-commune.js
# ADMIN_EMAIL="admin@mairie-cocody.ci"
# ADMIN_PASSWORD="CHANGE_ME"
